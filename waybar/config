{
  "layer": "top ",
  "mode": "dock",
  "exclusive": true,
  "passthrough": false,
  "position": "top",
  "height": 34,
  "width": "",
  "spacing": 0,
  "margin": 0,
  "margin-top": 5,
  "margin-bottom": 0,
  "margin-left": 5,
  "margin-right": 5,
  "fixed-center": true,
  "ipc": true,
  "bar_id": "bar-0",

  "modules-left": ["sway/workspaces"],
  "modules-center": ["custom/spotify"],
  "modules-right": ["sway/language", "pulseaudio", "network", "battery", "clock"],
  
  "sway/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "persistent_workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
    },
    "format": "{icon}",
    "format-icons": {
      "1": "пЂ•",
      "2": "оћ•",
      "3": "п™‹",
      "4": "п‰Ё",
      "5": "п†ј"
      },
    },

  "sway/window": {
    "max-length": 50,
    },

  "sway/language": {
      "format": "{}",
      "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
      "tooltip-format": "{long}"
    },

  "clock": {
    "format": "пЂ— {:%H:%M}",
    "tooltip-format": "{:%d %B %Y}"
    },

  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": ["оѓ‰"],
    "on-scroll-up": "light -A 5",
    "on-scroll-down": "light -U 5",
    },

  "battery": {
    "format": "{icon} {capacity}%",
	"states": {
		"warning": 30,
		"critical": 15
	},
    "format-icons": ["п•№", "п•є", "п•»", "п•ј", "п•Ѕ", "п•ѕ", "п•ї", "п–Ђ", "п–Ѓ", "п•ё"],
    },

  "network": {
    "interface": "wlp3s0f0",
    "format": " {ifname} ",
    "format-ethernet": "{ifname}",
    "format-wifi": "п‡«  {signalStrength}%",
    "format-linked": "пћ– {ifname} (No IP)",
    "format-disconnected": "пЄ© ",
    "format-alt": "Speed: {bandwidthDownBits}",
	"tooltip-format-wifi": "{essid}",
	"tooltip-format-disconnected": "Disconnected",
	"max-length":25
    },

  "pulseaudio": {
	"tooltip": false,
    //"format": "{icon} {volume}% {format_source}",
    "format": "{icon} {volume}%",
    "format-muted": "п‹ў ",
    "format-source": "п„° {volume}% ",
    "format-source-muted": "п„±",
    "format-icons": {
      "headphone": "пЂҐ",
      "default": ["пЂ¦", "пЂ§", "пЂЁ"]
      },
   // "on-click": "pavucontrol"
    },
   
   "custom/spotify": {
    "format": "п†ј  {}",
	"exec": "$HOME/.config/waybar/scripts/spotify.sh",
	"interval": 1,
	"smooth-scrolling-threshold": 20,
    "on-click": "playerctl -p spotify play-pause",
    "on-scroll-up": "playerctl -p spotify next",
    "on-scroll-down": "playerctl -p spotify previous",
	"exec-if": "pgrep spotify"
    },
 } 
